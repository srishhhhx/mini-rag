# ── LLMs ───────────────────────────────────────────────────────────────────
# Primary: Groq Llama 70B
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile

# Fallback: Groq Llama 8B
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# ── Embeddings (HuggingFace Inference API) ───────────────────────────────────
# Get free key at: https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_api_key_here
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Reranking (Cohere API) ────────────────────────────────────────────────────
# Get free key at: https://dashboard.cohere.com (1000 rerank calls/month free)
COHERE_API_KEY=your_cohere_api_key_here

# ── LangSmith Observability ─────────────────────────────────────────────────
# Get free key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=pdf-chat-rag

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=30

# ── Retrieval ───────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3
RRF_K=60
CONFIDENCE_THRESHOLD=0.01

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=500

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
